# ═══════════════════════════════════════════════════════════════════════════════
# EduPlatform — Self-Hosted Configuration
# ═══════════════════════════════════════════════════════════════════════════════
# Foydalanish:
#   cp .env.example .env
#   nano .env           ← barcha qiymatlarni to'ldiring
#   docker compose -f docker-compose.selfhost.yml up -d --build
# ═══════════════════════════════════════════════════════════════════════════════

# ── Server ───────────────────────────────────────────────────────────────────
# Serveringizning IP manzili yoki domen nomi (http:// siz)
# Misol: 185.197.249.26   yoki   school.mycompany.uz
SERVER_HOST=185.197.249.26

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_USER=eduplatform
POSTGRES_PASSWORD=EduPlatform_S3cr3t_2026!
POSTGRES_DB=eduplatform_db

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=Redis_S3cr3t_2026!

# ── JWT (kamida 32 belgili tasodifiy satr) ───────────────────────────────────
JWT_SECRET=change_me_to_a_very_long_random_string_at_least_32_chars
JWT_REFRESH_SECRET=change_me_to_another_very_long_random_string_32_chars

# ── App ───────────────────────────────────────────────────────────────────────
NODE_ENV=production
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
THROTTLE_TTL=60000
THROTTLE_LIMIT=100
LOG_LEVEL=info

# ── SMS (ixtiyoriy — bo'sh qoldirilsa log ga yozadi) ────────────────────────
INFOBIP_API_KEY=
INFOBIP_BASE_URL=
SMS_FROM=EduPlatform

# ── SMTP Email (ixtiyoriy) ────────────────────────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=EduPlatform <noreply@eduplatform.uz>

# ── To'lov tizimlari (ixtiyoriy) ─────────────────────────────────────────────
PAYME_MERCHANT_ID=
PAYME_SECRET_KEY=
CLICK_MERCHANT_ID=
CLICK_SECRET_KEY=

# ── Frontend (docker-compose uchun TALAB QILINADI) ──────────────────────────
# ⚠️  MUHIM: Bu qiymatlar FRONTEND BUILD vaqtida embed bo'ladi.
#    "localhost" qoldirish deployingiz ishlamaydi!
#    O'zingizning domen yoki IP manzilingizni yozing.
#
#    Misol (domen bilan):
#      NEXT_PUBLIC_API_URL=https://school.mycompany.uz/api/v1
#      NEXT_PUBLIC_WS_URL=https://school.mycompany.uz
#    Misol (IP bilan):
#      NEXT_PUBLIC_API_URL=http://185.197.249.26/api/v1
#      NEXT_PUBLIC_WS_URL=http://185.197.249.26
NEXT_PUBLIC_API_URL=http://localhost:3001/api/v1
NEXT_PUBLIC_WS_URL=http://localhost:3001

# ── App URL (docker-compose uchun TALAB QILINADI) ───────────────────────────
# ⚠️  MUHIM: Bu qiymatlar backend CORS, cookie va email linklari uchun ishlatiladi.
#    "localhost" qoldirish deployingiz ishlamaydi!
#
#    Misol (domen bilan):
#      APP_URL=https://school.mycompany.uz
#      ALLOWED_ORIGINS=https://school.mycompany.uz
#    Misol (IP bilan):
#      APP_URL=http://185.197.249.26
#      ALLOWED_ORIGINS=http://185.197.249.26
APP_URL=http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000

# ── Seed (birinchi deploy'da demo maktab va super admin yaratish) ───────────
# SEED_FORCE=true  → Bo'sh DB'ga demo maktab, filial, 9 ta demo user yaratadi
# SEED_FORCE=false → Seed o'tkazilmaydi (DB da userlar bo'lsa)
# Birinchi deploy'da true qiling, keyin false qilishingiz mumkin
SEED_FORCE=true

# ── Sentry (ixtiyoriy) ───────────────────────────────────────────────────────
SENTRY_DSN=
SENTRY_RELEASE=
LOG_QUERIES=false
