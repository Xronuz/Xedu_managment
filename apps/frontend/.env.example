# ── API ───────────────────────────────────────────────────────────────────────
# Backend REST API manzili (Next.js client va server tomonida ishlatiladi)
NEXT_PUBLIC_API_URL=http://localhost:3001/api/v1

# WebSocket server manzili (real-time bildirishnomalar uchun)
NEXT_PUBLIC_WS_URL=http://localhost:3001

# Frontend o'zining canonical URL-manzili (production uchun: https://xedu.uz)
# Redirect URL'lar va cookie sozlamalarida ishlatiladi.
NEXT_PUBLIC_APP_URL=http://localhost:3000
