# Mobil ilova muhit o'zgaruvchilari.
# Expo public env'lar EXPO_PUBLIC_ prefiksi bilan bo'lishi shart.
#
# ✅ TAVSIYA — to'g'ridan PRODUCTION'ga ulanish (lokal backend kerak emas):
#   EXPO_PUBLIC_API_URL=https://xedu.uz/api/v1
#
# Lokal backendga test (qurilma kompyuterga LAN orqali):
#   EXPO_PUBLIC_API_URL=http://192.168.X.X:3001/api/v1
# Android emulyator:    http://10.0.2.2:3001/api/v1
# iOS simulator:        http://localhost:3001/api/v1
EXPO_PUBLIC_API_URL=https://xedu.uz/api/v1
