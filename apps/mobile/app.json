{
  "expo": {
    "name": "Xedu",
    "slug": "xedu-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "xedu",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#0B1220"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "uz.xedu.mobile"
    },
    "android": {
      "package": "uz.xedu.mobile"
    },
    "web": {
      "bundler": "metro",
      "output": "static"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-localization",
      "expo-font",
      [
        "expo-notifications",
        {
          "color": "#0F7B53"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "apiUrl": "http://localhost:3001/api/v1"
    }
  }
}
