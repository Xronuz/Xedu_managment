# EduPlatform - Caddyfile
# HTTP only (Cloudflare handles SSL)
# platform.cybertron.uz  -> Next.js frontend + NestJS backend
# workload.cybertron.uz  -> PM2 workload (port 3002 backend, port 3003 vite preview)

{
    auto_https off
    servers {
        protocols h1 h2
    }
}

# =============================
# PLATFORM - platform.cybertron.uz (HTTP)
# =============================
http://platform.cybertron.uz {

    header {
        X-Frame-Options             "SAMEORIGIN"
        X-Content-Type-Options      "nosniff"
        X-XSS-Protection            "1; mode=block"
        Referrer-Policy             "strict-origin-when-cross-origin"
        -Server
    }

    request_body {
        max_size 50MB
    }

    encode zstd gzip

    @health path /api/health
    handle @health {
        reverse_proxy backend:3001
    }

    @auth path /api/v1/auth/*
    handle @auth {
        reverse_proxy backend:3001 {
            header_up X-Real-IP {http.request.remote.host}
            header_up Host      {http.request.host}
            transport http {
                response_header_timeout 30s
            }
        }
    }

    @api path /api/*
    handle @api {
        reverse_proxy backend:3001 {
            header_up X-Real-IP {http.request.remote.host}
            header_up Host      {http.request.host}
            transport http {
                response_header_timeout 60s
            }
        }
    }

    @websocket {
        path    /socket.io/*
        header  Connection *Upgrade*
        header  Upgrade    websocket
    }
    handle @websocket {
        reverse_proxy backend:3001 {
            header_up Connection {http.request.header.Connection}
            header_up Upgrade    {http.request.header.Upgrade}
            header_up Host       {http.request.host}
            transport http {
                read_timeout  0s
                write_timeout 0s
            }
        }
    }

    @static path /_next/static/*
    handle @static {
        header Cache-Control "public, max-age=31536000, immutable"
        reverse_proxy frontend:3000
    }

    @images path /_next/image*
    handle @images {
        header Cache-Control "public, max-age=604800"
        reverse_proxy frontend:3000 {
            header_up Host {http.request.host}
        }
    }

    @uploads path /uploads/*
    handle @uploads {
        header Cache-Control "public, max-age=604800"
        reverse_proxy backend:3001 {
            header_up Host {http.request.host}
        }
    }

    handle {
        reverse_proxy frontend:3000 {
            header_up X-Real-IP {http.request.remote.host}
            header_up Host      {http.request.host}
            transport http {
                response_header_timeout 30s
            }
        }
    }

    log {
        output file /var/log/caddy/access.log {
            roll_size 10mb
            roll_keep 5
        }
        format json
        level  INFO
    }
}

# =============================
# WORKLOAD - workload.cybertron.uz
# /api/* -> backend (172.18.0.1:3002), rest -> vite preview (172.18.0.1:3003)
# =============================
http://workload.cybertron.uz {

    encode zstd gzip

    # API calls -> workload Express backend
    @api path /api/*
    handle @api {
        reverse_proxy 172.18.0.1:3002 {
            header_up X-Real-IP {http.request.remote.host}
            header_up Host      {http.request.host}
        }
    }

    # Everything else -> workload Vite preview frontend
    # Host header set to localhost to bypass Vite host check
    handle {
        reverse_proxy 172.18.0.1:3003 {
            header_up X-Real-IP {http.request.remote.host}
            header_up Host      localhost
        }
    }

    log {
        output file /var/log/caddy/workload-access.log {
            roll_size 10mb
            roll_keep 5
        }
        format json
        level  INFO
    }
}
